# =============================================================================
# GovGrasp — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Database (PostgreSQL) ---
DB_DATABASE=govgrasp
DB_USER=postgres
DB_PASSWORD=change_me_in_production

# --- Backend (Laravel) ---
APP_KEY=                          # Generate with: php artisan key:generate
APP_ENV=local                     # local | production
APP_DEBUG=true
APP_URL=http://localhost:8000

# --- Python Worker / Ollama ---
OLLAMA_HOST=http://ollama:11434    # Ollama server (set to http://localhost:11434 outside Docker)
LLM_MODEL=llama3.2:1b             # Default: llama3.2:1b (~1.5 GB RAM). Use llama3.1:8b for higher quality (~6 GB RAM).

# --- AWS (only needed for deployment — not required for local docker compose) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-2
