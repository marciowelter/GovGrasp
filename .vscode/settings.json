{
    // ---------------------------------------------------
    // Global Editor Rules
    // ---------------------------------------------------
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    // Hide irrelevant folders from the file tree
    "files.exclude": {
        "**/.git": true,
        "**/.venv": true,
        "**/__pycache__": true,
        "**/.terraform": true,
        "**/.pytest_cache": true
    },
    // ---------------------------------------------------
    // Python (Worker) Settings
    // ---------------------------------------------------
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
        }
    },
    // ---------------------------------------------------
    // PHP (Backend Laravel) Settings
    // ---------------------------------------------------
    "[php]": {
        "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
        "editor.formatOnSave": true
    },
    // ---------------------------------------------------
    // DevSecOps (SonarLint) Settings
    // ---------------------------------------------------
    "sonarlint.rules": {
        // Example: disable specific rules if they generate many false positives
        // "php:S119": { "level": "off" }
    }
}
